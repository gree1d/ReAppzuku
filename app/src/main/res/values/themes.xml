        <item name="colorSurface">@color/amoled_background</item>
        <item name="colorSurfaceVariant">@color/amoled_surface_variant</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="android:colorControlActivated">@color/colorAccent</item>
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="checkboxStyle">@style/Widget.App.CheckBox</item>
    </style>

