<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sort_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <RadioGroup
        android:id="@+id/sort_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/sort_default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_default"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_ram_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_ram_desc"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_ram_asc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_ram_asc"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_name_asc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_name_asc"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_name_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_name_desc"
            android:padding="8dp" />

    </RadioGroup>
    
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <CheckBox
        android:id="@+id/checkbox_show_system"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_show_system_apps_title"
        android:padding="8dp" />

    <CheckBox
        android:id="@+id/checkbox_show_persistent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_show_persistent_apps_title"
        android:padding="8dp" />

</LinearLayout>
