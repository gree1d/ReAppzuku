<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    android:orientation="vertical"
    android:descendantFocusability="blocksDescendants">

    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@drawable/list_item_background"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/app_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            android:focusable="false"
            tools:src="@android:drawable/sym_def_app_icon" />

        <LinearLayout
            android:id="@+id/linear2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <!-- Строка 1: название + иконки.
                 ConstraintLayout позволяет точно разместить иконки сразу после текста:
                 app_name прижат к start, его end соединён с start иконок.
                 app_name имеет app:layout_constrainedWidth="true" — это ключевой атрибут,
                 который не даёт тексту растягиваться дальше доступного места,
                 заставляя его обрезаться через ellipsize вместо вытеснения иконок. -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:focusable="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/protected_icon"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constrainedWidth="true" />

                <ImageView
                    android:id="@+id/protected_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_protected"
                    android:visibility="gone"
                    android:focusable="false"
                    app:layout_constraintStart_toEndOf="@id/app_name"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/whitelist_icon"
                    app:layout_goneMarginStart="0dp" />

                <ImageView
                    android:id="@+id/whitelist_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_whitelist"
                    android:visibility="gone"
                    android:focusable="false"
                    app:layout_constraintStart_toEndOf="@id/protected_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_goneMarginStart="0dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Строка 2: пакет -->
            <TextView
                android:id="@+id/app_pkg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:focusable="false" />

            <!-- Строка 3: ОЗУ + бейджи System / Persistent -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/app_ram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/badge_system"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/badge_system"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="@string/badge_system"
                    android:textColor="#1A5276"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/badge_persistent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/badge_persistent"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="@string/badge_persistent"
                    android:textColor="#6C3483"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:focusable="false" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_overflow"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btn_overflow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="10dp">

            <ImageView
                android:id="@+id/btn_app_action"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_force_stop"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
