    <!-- Info dialog -->
    <string name="adb_info_title">Зачем нужен ADB-сервис?</string>
    <string name="adb_info_message">На Android 10+ SELinux блокирует команду \"ps\" при запуске через root.\n\nВ контексте ADB shell (Беспроводная отладка) та же команда работает корректно — именно так работает Shizuku.\n\nКак подключиться:\n1. Нажмите «Запустить сервис»\n2. В открывшихся настройках включите «Беспроводная отладка»\n3. Нажмите «Подключить устройство с помощью ввода кода»\n4. Введите PORT:КОД из диалога в уведомление приложения\n\n⚠ При перезагрузке потребуется повторное подключение.</string>
    <string name="adb_info_btn_ok">Понятно</string>

